from pyspark.sql import functions as F
import numpy as np
from scipy.stats import ks_2samp

score_col = "geo_dispersion_score"
flag_col = "bad_flg"

# ---------------------------------------------
# 1) Pull good / bad score arrays to pandas/numpy
# ---------------------------------------------
pdf = (
    df_comb
    .select(score_col, flag_col)
    .filter(F.col(score_col).isNotNull())
    .filter(F.col(flag_col).isNotNull())
    .toPandas()
)

good = pdf.loc[pdf[flag_col] == 0, score_col].values
bad  = pdf.loc[pdf[flag_col] == 1, score_col].values

print(f"n_good = {len(good):,}")
print(f"n_bad  = {len(bad):,}")

# ---------------------------------------------
# 2) KS test
# ---------------------------------------------
ks_res = ks_2samp(good, bad, alternative="two-sided", method="asymp")

print(f"KS statistic = {ks_res.statistic:.6f}")
print(f"p-value      = {ks_res.pvalue:.6g}")

# ---------------------------------------------
# 3) Simple interpretation
# ---------------------------------------------
alpha = 0.05

if ks_res.pvalue < alpha:
    print("Result: statistically significant separation at 5% level.")
else:
    print("Result: NOT statistically significant at 5% level.")


import numpy as np
import matplotlib.pyplot as plt

good_sorted = np.sort(good)
bad_sorted  = np.sort(bad)

good_cdf = np.arange(1, len(good_sorted) + 1) / len(good_sorted)
bad_cdf  = np.arange(1, len(bad_sorted) + 1) / len(bad_sorted)

plt.figure(figsize=(7,5))
plt.plot(good_sorted, good_cdf, label="Good")
plt.plot(bad_sorted, bad_cdf, label="Bad")

plt.xlabel("Geo Dispersion Score")
plt.ylabel("Empirical CDF")
plt.title(f"KS Separation for {score_col}\nKS = {ks_res.statistic:.4f}, p = {ks_res.pvalue:.3g}")
plt.legend()
plt.grid(alpha=0.3)
plt.show()

